{
  "name": "codemap",
  "version": "0.0.0",
  "private": true,
  "description": "◆ Understand any codebase in 5 minutes",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:scanner": "npm run build --workspace=@codemap/scanner",
    "build:visualizer": "npm run build --workspace=@codemap/visualizer",
    "build:cli": "npm run build --workspace=@codemap/cli",
    "dev": "npm run dev --workspace=@codemap/visualizer",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
